# ── LLM ──
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-key-here
# 输入你的 LLM API Key，如果使用 DeepSeek，确保在 https://www.deepseek.com/dashboard/api-keys 创建一个 API Key 并替换上面的值。
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
# 兼容旧变量名（LLM_API_KEY 未设置时回退）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 服务端口 ──
PORT=3099
DB_PATH=./data/agent.db

# ── 向量服务 ──
VECTOR_SERVICE_URL=http://localhost:8765

# ── ComfyUI ──
COMFYUI_URL=http://localhost:8188
COMFYUI_OUTPUT_DIR=./output
COMFYUI_ARTIST=@ebora
COMFYUI_WIDTH=768
COMFYUI_HEIGHT=512
COMFYUI_MOMENTS_ARTIST=@ebora
COMFYUI_MOMENTS_WIDTH=1600
COMFYUI_MOMENTS_HEIGHT=1200

# ── Feature Flags (true/false) ──
FEATURE_EMOTION=true
FEATURE_MEMORY=true
FEATURE_PROMPT_OPTIMIZE=false
FEATURE_REPLY_GUESSES=true
FEATURE_FORCE_IMAGE_GEN=false
FEATURE_REALTIME_AFFINITY_DISPLAY=false
FEATURE_PROACTIVE_CHAT=true
PROACTIVE_CHAT_FREQ=0.1

# ── 用户信息（首次启动种子，之后由 system_settings 表接管） ──
USER_NICKNAME=用户
USER_GENDER=
USER_APPEARANCE=
USER_PERSONA=
